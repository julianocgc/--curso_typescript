{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "lib": ["ESNext"],

        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",

        "rootDir": "./src",
        "outDir": "./build",

        "types": ["node"],

        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noEmitOnError": true,
        
        "verbatimModuleSyntax": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}